{
  "name": "wunschlachen-crm",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx pnpm@9 --filter app dev",
    "build": "npx pnpm@9 --filter app build",
    "generate": "npx pnpm@9 --filter app generate && mkdir -p .output && cp -r app/.output/public .output/public",
    "preview": "npx pnpm@9 --filter app preview",
    "postinstall": "npx pnpm@9 --filter app postinstall"
  },
  "devDependencies": {
    "nuxt": "3.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "nuxt": "3.20.0",
      "vite": "^6.3.0"
    }
  }
}
