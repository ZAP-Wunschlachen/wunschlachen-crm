# Directus
DIRECTUS_URL=https://wunschlachen.app
AUTH_URL=https://login.wunschlachen.app
SOCKET_URL=wss://wunschlachen.app

# Brevo — server-only (in runtimeConfig, NICHT public)
# Wird von /api/brevo/send-email genutzt (server-side Proxy)
BREVO_TOKEN=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Wunschlachen

# Placetel
PLACETEL_API_KEY=

# Synthflow (AI Voice Agent)
SYNTHFLOW_API_KEY=
SYNTHFLOW_WEBHOOK_SECRET=

# CloudTalk (Power Dialer)
CLOUDTALK_API_KEY=

# Phase 9 Ticket-System — server-only
# WhatsApp Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# Cron-Auth für /api/tickets/sla-check + auto-assign
CRON_SECRET=

# Comma-separated list erlaubter Origins für /api/inbound/form
# z.B. "https://wunschlachen.de,https://www.wunschlachen.de"
FORM_ALLOWED_ORIGINS=

# Dev-only: Auth komplett überspringen (Mock-User)
# Nur in .env.local setzen, NIEMALS in Production!
# NUXT_PUBLIC_DEV_AUTH_BYPASS=1
